<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tips"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="16dp"/>

        <!-- Tip cards -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="14dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🏠"
                    android:textSize="22sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Maximize Catchment Area" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/on_surface"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keep your roof clean. A clean 80m² roof can collect up to 56,000 L/year."
                        android:textSize="12sp" android:textColor="@color/on_surface_variant" android:lineSpacingMultiplier="1.4" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="14dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🔧"
                    android:textSize="22sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Use First-Flush Diverters" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/on_surface"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Discard the first 20–25L of rain to remove dust and pollutants from the roof surface."
                        android:textSize="12sp" android:textColor="@color/on_surface_variant" android:lineSpacingMultiplier="1.4" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="14dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🌿"
                    android:textSize="22sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Prioritize Smart Usage" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/on_surface"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Use harvested water for garden irrigation and toilet flushing first — covers ~40% of needs."
                        android:textSize="12sp" android:textColor="@color/on_surface_variant" android:lineSpacingMultiplier="1.4" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="14dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="🛡️"
                    android:textSize="22sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Inspect Tanks Monthly" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/on_surface"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keep tanks covered to prevent mosquito breeding. Check for cracks before every monsoon."
                        android:textSize="12sp" android:textColor="@color/on_surface_variant" android:lineSpacingMultiplier="1.4" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
